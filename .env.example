# .env.example — onto repo wrapper environment template
#
# 이 파일은 commit 됩니다. 실제 값을 담은 `.env` 는 gitignore 됩니다 —
# 직접 cp 후 값 채워서 사용하세요.
#
# 사용 방법:
#   cp .env.example .env
#   # .env 편집 후
#   set -a; source .env; set +a    # 모든 var 를 export
#
# 또는 shell rc (.zshrc 등) 에 직접 export.

# ──────────────────────────────────────────────────────────────────────
# Provider auth — `bash scripts/review-pr.sh --provider <name>` 사용 시
# 해당 provider 만 필요. 모든 provider 를 한번에 쓸 일은 없으므로
# 본인이 사용할 provider 의 값만 채우세요.
# ──────────────────────────────────────────────────────────────────────

# Anthropic API (provider=anthropic 시 필수)
# 발급: https://console.anthropic.com/account/keys
# ANTHROPIC_API_KEY=sk-ant-api03-...

# OpenAI API (provider=openai 시 필수)
# 또는 ~/.codex/auth.json 의 OPENAI_API_KEY field 도 fallback 으로 read.
# 발급: https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-...

# litellm proxy endpoint (provider=litellm 시 필수)
# 가이드: https://docs.litellm.ai/docs/proxy/quick_start
# LITELLM_BASE_URL=http://localhost:4000

# Codex provider (provider=codex) 는 env 가 아니라 ~/.codex/auth.json
# 으로 인증합니다 — `codex login` 으로 auth.json 생성. 별도 env 불필요.

# ──────────────────────────────────────────────────────────────────────
# review-pr.sh wrapper-specific overrides
# (CLI flag 의 env 형태 — flag 가 우선, env 가 다음, script default 가 마지막)
# ──────────────────────────────────────────────────────────────────────

# Default provider when `--provider` flag 미지정.
# Allowed: codex | anthropic | openai | litellm
# Script default: codex
# REVIEW_PR_PROVIDER=codex

# Default model_id when `--model` flag 미지정.
# Per-provider wrapper defaults (provider 가 결정되어야 의미 있음):
#   codex     → gpt-5.4
#   anthropic → claude-sonnet-4-6
#   openai    → gpt-5.4
#   litellm   → (wrapper default 없음 — flag 또는 env 명시 필수)
# REVIEW_PR_MODEL=gpt-5.5

# Default effort when `--effort` flag 미지정.
# Per-provider valid set:
#   codex / openai / litellm  → low | medium | high | xhigh
#   anthropic                 → low | medium | high
# Script default: high
# REVIEW_PR_EFFORT=high

#!/usr/bin/env node

// Global CLI entry point for onto.
// Uses tsx for TypeScript execution in development.
// For production, compile first: npm run build
//
// Product Locality Principle (.onto/principles/product-locality-principle.md):
// If a project-local installation exists, delegate execution to it.
// --global flag bypasses delegation.

import { fileURLToPath } from "node:url";
import path from "node:path";
import { execSync } from "node:child_process";
import fs from "node:fs";

const __dirname = path.dirname(fileURLToPath(import.meta.url));
const ontoRoot = path.resolve(__dirname, "..");

// ---------------------------------------------------------------------------
// Project-local delegation (§2.1)
// ---------------------------------------------------------------------------

function findProjectRoot(startDir) {
  let dir = startDir;
  while (true) {
    if (
      fs.existsSync(path.join(dir, ".onto", "config.yml")) ||
      fs.existsSync(path.join(dir, ".git")) ||
      fs.existsSync(path.join(dir, "package.json"))
    ) {
      return dir;
    }
    const parent = path.dirname(dir);
    if (parent === dir) return startDir;
    dir = parent;
  }
}

function tryDelegateToLocal(argv) {
  if (argv.includes("--global")) return false;

  const projectRoot = findProjectRoot(process.cwd());
  const localBin = path.join(projectRoot, "node_modules", "onto-core", "bin", "onto");

  // Don't delegate to ourselves
  if (!fs.existsSync(localBin)) return false;
  const resolvedLocal = fs.realpathSync(localBin);
  const resolvedSelf = fs.realpathSync(fileURLToPath(import.meta.url));
  if (resolvedLocal === resolvedSelf) return false;

  // CON-2: Force ONTO_HOME to the local installation to prevent resource mismatch (§3 #5)
  const localOntoRoot = path.resolve(path.dirname(localBin), "..");
  try {
    execSync(`"${process.execPath}" "${localBin}" ${argv.map(a => `"${a}"`).join(" ")}`, {
      stdio: "inherit",
      cwd: process.cwd(),
      env: { ...process.env, ONTO_HOME: localOntoRoot },
    });
  } catch (error) {
    process.exit(error && typeof error === "object" && "status" in error ? Number(error.status) || 1 : 1);
  }
  process.exit(0);
}

const userArgs = process.argv.slice(2);

if (!tryDelegateToLocal(userArgs)) {
  // ---------------------------------------------------------------------------
  // No local installation — run from this (global/development) binary.
  //
  // P1-3 (catalog → runtime authority): the entry point is the catalog-
  // derived `dispatcher.ts`. It routes by phase — preboot → preboot-dispatch.ts,
  // post_boot → cli.ts main(). bin/onto stays Delegation/Handoff only.
  // ---------------------------------------------------------------------------

  const distDispatcher = path.join(ontoRoot, "dist", "core-runtime", "cli", "dispatcher.js");
  const srcDispatcher = path.join(ontoRoot, "src", "core-runtime", "cli", "dispatcher.ts");

  process.env.ONTO_HOME = process.env.ONTO_HOME ?? ontoRoot;

  if (fs.existsSync(distDispatcher)) {
    // Production: import the compiled dispatcher and call dispatch().
    const { dispatch } = await import(distDispatcher);
    const code = await dispatch(userArgs);
    process.exit(code ?? 0);
  } else {
    // Development: spawn tsx with dispatcher.ts as the entry. The generated
    // dispatcher.ts has an `import.meta.url`-gated auto-call that fires when
    // it is the process entry, mirroring cli.ts's pattern.
    const tsxBin = path.join(ontoRoot, "node_modules", ".bin", "tsx");
    const args = [srcDispatcher, ...userArgs];
    try {
      execSync(`"${tsxBin}" ${args.map(a => `"${a}"`).join(" ")}`, {
        stdio: "inherit",
        cwd: process.cwd(),
        env: { ...process.env, ONTO_HOME: ontoRoot },
      });
    } catch (error) {
      process.exit(error && typeof error === "object" && "status" in error ? Number(error.status) || 1 : 1);
    }
  }
}

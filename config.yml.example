# config.yml.example — onto project configuration template
#
# Copy this file to {project}/.onto/config.yml and adjust for your
# environment. The `.onto/` directory is gitignored, so your local
# settings never leak to the remote repo.
#
# Full OntoConfig surface (every key, every valid value, resolution
# chain, merge strategy): processes/configuration.md.
# Type source of truth: src/core-runtime/discovery/config-chain.ts.
#
# This file is the minimal shape most contributors need. Keys not
# shown here default sensibly — `onto onboard` will prompt for the
# ones you need on first run.

# ─────────────────────────────────────────────────────────────────
# Output language — principal-facing output ONLY
# ─────────────────────────────────────────────────────────────────
# Agent prompts, wip.yml, session-log.yml and every inter-agent
# hand-off stay in English regardless of this value. Translation
# happens only at the Runtime Coordinator's render seat.
# See: design-principles/output-language-boundary.md
output_language: en           # en | ko | ja | ...

# ─────────────────────────────────────────────────────────────────
# Domains (optional)
# ─────────────────────────────────────────────────────────────────
# Unordered set of domains applicable to this project. Per-session
# selection via `--domain {name}` or `--no-domain`. Omit this block
# to pick a domain interactively each session.
# domains:
#   - software-engineering
#   - ontology

# ─────────────────────────────────────────────────────────────────
# Review execution axes — canonical as of Review UX Redesign (2026-04-21)
# ─────────────────────────────────────────────────────────────────
# The `review:` block declares 6 user-facing axes. Runtime derives one of
# 6 internal TopologyShapes (main_native / main_foreign / main-teams_*
# / ext-teamlead_native) and dispatches accordingly.
#
# Omit `review:` entirely to use universal fallback (equivalent to
# teamlead=main + subagent=main-native + synthesizer-only deliberation).
#
# Use `onto config edit` for interactive stepwise setup, or
# `onto config set <key> <value>` for single-field mutation.
# Use `onto config validate` to preview the derived TopologyId under
# current host signals before running a review.
#
# Design doc: development-records/evolve/20260420-review-execution-ux-redesign.md
# Type source: src/core-runtime/discovery/config-chain.ts (OntoReviewConfig)
#
# review:
#   teamlead:
#     model: main                   # "main" = host session (default)
#                                   # External: {provider: codex, model_id: gpt-5.4, effort: high}
#   subagent:
#     provider: main-native         # main-native | codex | anthropic | openai | litellm
#     # model_id: gpt-5.4           # required when provider != main-native
#     # effort: high                # provider-specific reasoning effort
#   # max_concurrent_lenses: 6      # provider default applies when omitted
#                                   # codex default: 6 / main-native: num_lenses
#                                   # litellm default: 1-2
#   # lens_deliberation: synthesizer-only   # or sendmessage-a2a (requires teams)

# ─────────────────────────────────────────────────────────────────
# Subagent LLM (background task LLM — learn / govern / promote)
# ─────────────────────────────────────────────────────────────────
# Still consulted by background tasks (not review execution — review
# uses the `review.subagent` block above).
# See processes/configuration.md §4.3 for full sub-field reference.
#
# subagent_llm:
#   provider: litellm             # anthropic | openai | litellm | codex
#   model: claude-sonnet-4-6
#   base_url: http://localhost:4000/v1   # required when provider=litellm
#   max_tokens: 4096
#   tool_mode: auto               # auto | native | inline. default auto

# ─────────────────────────────────────────────────────────────────
# Background task LLM (learn / govern / promote) — optional
# ─────────────────────────────────────────────────────────────────
# Omit for cost-order auto-resolution: codex OAuth > LiteLLM >
# Anthropic > OpenAI. Set explicitly to force a specific provider.
# api_provider: anthropic         # anthropic | openai | litellm | codex

# ─────────────────────────────────────────────────────────────────
# Top-level `max_concurrent_lenses` (legacy — prefer `review.max_concurrent_lenses`)
# ─────────────────────────────────────────────────────────────────
# Kept for projects that haven't migrated to the `review:` block.
# Lower for constrained environments. Local LLM with a single GPU: 1.
# max_concurrent_lenses: 9

# ─────────────────────────────────────────────────────────────────
# Learning extraction mode — optional (default disabled)
# ─────────────────────────────────────────────────────────────────
# disabled : skip extraction
# shadow   : run extractor + write manifest, do NOT update live learnings
# active   : update .onto/learnings/ during review
# learning_extract_mode: disabled

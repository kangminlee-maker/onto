{
  "name": "onto-core",
  "version": "0.2.2",
  "description": "Ontology-as-Code productization core — 9-lens review, domain knowledge management, deterministic state enforcement",
  "onto_release_channel": "beta",
  "onto_release_label": "onto-harness",
  "type": "module",
  "bin": {
    "onto": "./bin/onto"
  },
  "files": [
    "bin/",
    "dist/",
    ".claude-plugin/",
    ".onto/roles/",
    ".onto/domains/",
    ".onto/authority/",
    ".onto/commands/",
    ".onto/processes/",
    ".onto/principles/",
    "explorers/",
    "CLAUDE.md",
    "AGENTS.md",
    "process.md",
    "learning-rules.md",
    "config.yml.example"
  ],
  "scripts": {
    "prepare": "npm run build:ts-core",
    "build:ts-core": "tsc -p tsconfig.json",
    "check:ts-core": "tsc -p tsconfig.json --noEmit",
    "lint:output-language-boundary": "tsx scripts/lint-output-language-boundary.ts",
    "generate:catalog": "tsx scripts/generate-command-catalog-derived.ts",
    "check:catalog-drift": "tsx scripts/check-catalog-drift.ts",
    "check:handler-exports": "tsx scripts/check-handler-exports.ts",
    "check:contract-refs": "tsx scripts/check-contract-refs.ts",
    "test:e2e": "bash src/core-runtime/cli/e2e-review-invoke.test.sh",
    "test:e2e:promote": "tsx src/core-runtime/learning/promote/e2e-promote.test.ts",
    "test:e2e:start-review-session": "tsx src/core-runtime/cli/e2e-start-review-session.test.ts",
    "test:e2e:codex-multi-agent-fixes": "tsx src/core-runtime/cli/e2e-codex-multi-agent-fixes.test.ts",
    "review:invoke": "tsx src/core-runtime/cli/review-invoke.ts",
    "review:start-session": "tsx src/core-runtime/cli/start-review-session.ts",
    "review:run-prompt-execution": "tsx src/core-runtime/cli/run-review-prompt-execution.ts",
    "review:complete-session": "tsx src/core-runtime/cli/complete-review-session.ts",
    "review:prepare-session": "tsx src/core-runtime/cli/prepare-review-session.ts",
    "review:bootstrap-binding": "tsx src/core-runtime/cli/bootstrap-review-binding.ts",
    "review:materialize-execution-preparation": "tsx src/core-runtime/cli/materialize-review-execution-preparation.ts",
    "review:materialize-prompt-packets": "tsx src/core-runtime/cli/materialize-review-prompt-packets.ts",
    "review:codex-unit-executor": "tsx src/core-runtime/cli/codex-review-unit-executor.ts",
    "review:mock-unit-executor": "tsx src/core-runtime/cli/mock-review-unit-executor.ts",
    "review:inline-http-unit-executor": "tsx src/core-runtime/cli/inline-http-review-unit-executor.ts",
    "review:render-final-output": "tsx src/core-runtime/cli/render-review-final-output.ts",
    "review:finalize-session": "tsx src/core-runtime/cli/assemble-review-record.ts",
    "review:assemble-record": "tsx src/core-runtime/cli/assemble-review-record.ts",
    "review:write-interpretation": "tsx src/core-runtime/cli/write-review-interpretation.ts",
    "review:watch": "bash scripts/onto-review-watch.sh",
    "review:coordinator-init-log": "tsx src/core-runtime/cli/coordinator-helpers.ts init-log",
    "review:coordinator-build-synthesize-packet": "tsx src/core-runtime/cli/coordinator-helpers.ts build-synthesize-packet",
    "review:coordinator-write-execution-result": "tsx src/core-runtime/cli/coordinator-helpers.ts write-execution-result",
    "coordinator:start": "tsx src/core-runtime/cli/coordinator-state-machine.ts start",
    "coordinator:next": "tsx src/core-runtime/cli/coordinator-state-machine.ts next",
    "coordinator:status": "tsx src/core-runtime/cli/coordinator-state-machine.ts status",
    "onboard:detect-review-axes": "tsx src/core-runtime/onboard/detect-review-axes.ts",
    "onboard:write-review-block": "tsx src/core-runtime/onboard/write-review-block.ts",
    "migrate:agent-id-rename": "bash scripts/migrate-agent-id-rename.sh"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.82.0",
    "openai": "^6.33.0",
    "yaml": "^2.8.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.3.5",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
